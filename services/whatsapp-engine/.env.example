NODE_ENV=development
ENGINE_NAME=yemenstack-whatsapp-engine
ENGINE_POLL_INTERVAL_MS=5000
LARAVEL_BASE_URL=http://127.0.0.1:8000
ENGINE_API_TOKEN=
WHATSAPP_ENGINE_INTERNAL_TOKEN=
ENGINE_PENDING_MESSAGES_PATH=/api/v1/whatsapp/engine/messages/pending
ENGINE_QUEUED_MESSAGES_PATH=/api/v1/whatsapp/engine/messages/queued
ENGINE_ACCOUNT_STATUS_PATH=/api/v1/whatsapp/engine/account/status
ENGINE_CLAIM_MESSAGE_PATH_TEMPLATE=/api/v1/whatsapp/engine/messages/:id/claim
ENGINE_MARK_SENT_PATH_TEMPLATE=/api/v1/whatsapp/engine/messages/:id/mark-sent
ENGINE_MARK_FAILED_PATH_TEMPLATE=/api/v1/whatsapp/engine/messages/:id/mark-failed
WHATSAPP_SESSION_ID=
WHATSAPP_CHROME_PATH=
WHATSAPP_HEADLESS=true
WHATSAPP_QR_TERMINAL_SMALL=true
ENABLE_REAL_WHATSAPP_SEND=false
WHATSAPP_TEST_RECIPIENT=
ENGINE_FETCH_LIMIT=10
WHATSAPP_SEND_LIMIT=1
WHATSAPP_RESTART_DELAY_MS=3000
WHATSAPP_RESTART_TIMEOUT_MS=60000
WHATSAPP_MAX_RESTART_ATTEMPTS=3